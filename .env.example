# Claudomate Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# GitHub Authentication (choose one method)
# ===========================================

# Option 1: Personal Access Token (simpler)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: GitHub App (more secure, better for teams)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
# GITHUB_APP_INSTALLATION_ID=12345678

# ===========================================
# Webhook Configuration
# ===========================================

# Secret for verifying GitHub webhook signatures
# Generate with: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# Server Configuration
# ===========================================

# Port for claudomate server
PORT=3002

# ===========================================
# Project Configuration
# ===========================================

# Default target repository (owner/repo format)
TARGET_REPO=yourusername/your-project

# Base path where worktrees will be created
# Example: /home/user/projects
WORKTREE_BASE_PATH=/home/jut/projects

# Path to the main checkout of the target repo
TARGET_REPO_PATH=/home/jut/projects/your-project
